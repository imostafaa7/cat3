#!/bin/bash

# cat3 - Advanced Vulnerability Scanner & Recon Framework
# Optimized for Nuclei & Anti-Blocking

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m'

# ASCII Art Header
clear
echo -e "${CYAN}"
echo "  ____    _    __  __  ______ "
echo " / ___|  / \  |  \/  ||  ____|"
echo "| |     / _ \ | |\/| || |__   "
echo "| |___ / ___ \| |  | ||  __|  "
echo " \____/_/   \_\_|  |_||______|"
echo -e "       ${PURPLE}Powered by Nuclei | Anti-Block Edition${NC}"
echo "#################################################"

if [ -z "$1" ]; then
    echo -e "${RED}Usage: ./cat3.sh <domain>${NC}"
    exit 1
fi

DOMAIN=$1
OUT_DIR="cat3_$DOMAIN"
mkdir -p $OUT_DIR/recon $OUT_DIR/nuclei

# Anti-Blocking Configuration
RATE_LIMIT=10    # Requests per second (Low = Safer)
CONCURRENCY=5    # Simultaneous hosts
TIMEOUT=5        # Timeout in seconds

show_menu() {
    echo -e "\n${YELLOW}--- [ cat3 Control Panel ] ---${NC}"
    echo -e "${BLUE}1)${NC} Full Stealth Recon (Subdomains -> Alive -> Nuclei)"
    echo -e "${BLUE}2)${NC} Quick Nuclei Scan (Critical & High Only)"
    echo -e "${BLUE}3)${NC} Deep Analysis (All Templates - Slow Mode)"
    echo -e "${BLUE}4)${NC} Subdomain Enumeration Only"
    echo -e "${BLUE}5)${NC} Update Nuclei Templates"
    echo -e "${RED}0)${NC} Exit"
    echo -n "Select Action: "
}

do_recon() {
    echo -e "${GREEN}[*] Phase 1: Enumerating Subdomains...${NC}"
    subfinder -d $DOMAIN -silent -o $OUT_DIR/recon/subs.txt
    assetfinder --subs-only $DOMAIN >> $OUT_DIR/recon/subs.txt
    sort -u $OUT_DIR/recon/subs.txt -o $OUT_DIR/recon/subs.txt
    
    echo -e "${GREEN}[*] Phase 2: Filtering Alive Hosts (httpx)...${NC}"
    cat $OUT_DIR/recon/subs.txt | httpx -silent -o $OUT_DIR/recon/alive.txt
    echo -e "${CYAN}[+] Found $(wc -l < $OUT_DIR/recon/alive.txt) alive hosts.${NC}"
}

run_nuclei() {
    local mode=$1
    local templates=""

    case $mode in
        "stealth")
            echo -e "${YELLOW}[*] Running Stealth Scan (Critical/High)...${NC}"
            templates="-severity critical,high"
            ;;
        "deep")
            echo -e "${YELLOW}[*] Running Deep Scan (All Templates)...${NC}"
            templates="" # All templates
            RATE_LIMIT=5 # Slower for deep scan to avoid WAF
            ;;
    esac

    # Nuclei Command with Anti-Blocking Flags
    # -rl: rate limit | -c: concurrency | -bs: bulk size | -timeout: timeout
    nuclei -l $OUT_DIR/recon/alive.txt $templates \
           -rl $RATE_LIMIT -c $CONCURRENCY \
           -timeout $TIMEOUT -bs 1 \
           -header "User-Agent: Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/114.0.0.0 Safari/537.36" \
           -o $OUT_DIR/nuclei/results.txt

    echo -e "${CYAN}[+] Scan complete. Results: $OUT_DIR/nuclei/results.txt${NC}"
}

while true; do
    show_menu
    read opt
    case $opt in
        1) do_recon; run_nuclei "stealth" ;;
        2) if [ ! -f $OUT_DIR/recon/alive.txt ]; then do_recon; fi; run_nuclei "stealth" ;;
        3) if [ ! -f $OUT_DIR/recon/alive.txt ]; then do_recon; fi; run_nuclei "deep" ;;
        4) do_recon ;;
        5) nuclei -ut ;;
        0) exit 0 ;;
        *) echo -e "${RED}Invalid option!${NC}" ;;
    esac
done
